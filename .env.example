# ─── Variáveis de Ambiente — AutomationExercise CI/CD ────────────────────────
# Copie este arquivo para .env e preencha os valores reais
# NUNCA comite o arquivo .env no repositório

# ── Cypress ──────────────────────────────────────────────────────────────────
CYPRESS_baseUrl=https://automationexercise.com
CYPRESS_allure=true

# ── Docker / ghcr.io ─────────────────────────────────────────────────────────
# Configurar como secrets no GitHub Actions:
# Settings → Secrets and variables → Actions → New repository secret
#
# GITHUB_TOKEN  → gerado automaticamente pelo GitHub Actions (não precisa criar)
# IMAGE_NAME    → automático via github.repository

# ── Jenkins ──────────────────────────────────────────────────────────────────
# Configurar como secrets no GitHub Actions:
JENKINS_URL=http://SEU_JENKINS:8080
JENKINS_JOB_NAME=cypress-automation
JENKINS_USER=seu-usuario-jenkins
JENKINS_TOKEN=seu-api-token-jenkins   # Jenkins → Usuário → Configure → API Token

# Configurar como Credentials no Jenkins (tipo: Username with password):
# ID: ghcr-credentials
# Username: seu-usuario-github
# Password: Personal Access Token com escopo read:packages
